{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@latest",
    "@plannotator/opencode@latest"
  ],
  "small_model": "openai/gpt-5.3-codex-spark",
  "default_agent": "Bob",
  "agent": {
    "PlanB": {
      "mode": "primary",
      "description": "Dialogue-first planning agent",
      "model": "openai/gpt-5.4"
    },
    "Bob": {
      "mode": "primary",
      "description": "Default build agent for ordinary repo-local work",
      "model": "openai/gpt-5.3-codex-spark"
    },
    "Scuba": {
      "mode": "primary",
      "description": "Explicit codex-style deep-work agent",
      "model": "openai/gpt-5.3-codex"
    },
    "explore": {
      "mode": "subagent",
      "description": "Focused codebase search specialist",
      "model": "opencode-go/kimi-k2.5"
    },
    "librarian": {
      "mode": "subagent",
      "description": "External docs and examples specialist",
      "model": "opencode-go/kimi-k2.5"
    },
    "oracle": {
      "mode": "subagent",
      "description": "Strategic consultation specialist",
      "model": "openai/gpt-5.4"
    },
    "momus": {
      "mode": "subagent",
      "description": "Higher-rigor review specialist",
      "model": "openai/gpt-5.3-codex"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    },
    "terraform": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ]
    },
    "aws-terraform": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.terraform-mcp-server@latest"
      ]
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    }
  }
}
