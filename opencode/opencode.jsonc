{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest",
    // [
    //   "oc-plugin-vault-tec",
    //   {
    //     "enabled": false,
    //     "mode": "append"
    //   }
    // ]
  ],
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "Bob",
  "permission": {
    "websearch": "allow"
  },
  "tools": {
    "submit_plan": true
  },
  "agent": {
    "Bob": {
      "mode": "primary",
      "description": "Default build agent for ordinary repo-local work",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "medium",
      "prompt": "{file:./prompts/bob-gpt54-harness.md}",
      "color": "#7DAEA3",
      "permission": {
        "question": "allow"
      }
    },
    "Scuba": {
      "mode": "primary",
      "description": "Explicit codex-style deep-work agent",
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./prompts/scuba-codex-harness.md}",
      "color": "#8A7DFF",
      "tools": {
        "submit_plan": false
      }
    },
    "explore": {
      "mode": "subagent",
      "description": "Focused codebase search specialist",
      "model": "opencode-go/minimax-m2.7",
      "prompt": "{file:./prompts/explore-codex-harness.md}"
    },
    "explore-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback codebase search specialist when Kimi is unavailable",
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "none",
      "prompt": "{file:./prompts/explore-codex-harness.md}"
    },
    "librarian": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.1",
      "description": "External docs and examples specialist",
      "prompt": "{file:./prompts/librarian-codex-harness.md}"
    },
    "librarian-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback docs specialist when Kimi is unavailable",
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "none",
      "prompt": "{file:./prompts/librarian-codex-harness.md}"
    },
    "oracle": {
      "mode": "subagent",
      "description": "Strategic consultation specialist",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./prompts/oracle-codex-harness.md}"
    }
  },
  "mcp": {
    "terraform": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ]
    },
    "aws-terraform": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.terraform-mcp-server@latest"
      ]
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "greptile": {
      "type": "remote",
      "url": "https://api.greptile.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:GREPTILE_API_KEY}"
      }
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio"
      ],
      "environment": {
        "SLACK_MCP_ENABLED_TOOLS": "channels_list,conversations_history,conversations_replies,conversations_search_messages,usergroups_list,usergroups_me",
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_XOXB_TOKEN": "{env:SLACK_MCP_XOXB_TOKEN}",
        "SLACK_MCP_XOXC_TOKEN": "{env:SLACK_MCP_XOXC_TOKEN}",
        "SLACK_MCP_XOXD_TOKEN": "{env:SLACK_MCP_XOXD_TOKEN}"
      }
    }
  }
}
