{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest",
    // [
    //   "oc-plugin-vault-tec",
    //   {
    //     "enabled": false,
    //     "mode": "append"
    //   }
    // ]
  ],
  "instructions": ["prompts/pstack-compatibility.md"],
  "small_model": "openai/gpt-5.4-mini",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.6-sol": {
          "options": {
            "textVerbosity": "low"
          }
        }
      }
    }
  },
  "lsp": true,
  "references": {
    "effect-src": {
      "repository": "Effect-TS/effect",
      "description": "Use when writing or reviewing Effect code"
    },
    "opencode-src": {
      "repository": "anomalyco/opencode",
      "description": "Use when you need good examples of architecture, design, patterns, practices and style guide in Typescript/Effect repos"
    },
    "pi-src": {
      "repository": "earendil-works/pi",
      "description": "Use when you need good examples of architecture, design, patterns, practices and style guide in Typescript repos"
    }
  },
  "permission": {
    "websearch": "allow",
    "question": "allow",
    "skill": {
      "*": "allow",
      "architect": "deny",
      "arena": "deny",
      "automate-me": "deny",
      "blast-radius": "deny",
      "figure-it-out": "deny",
      "how": "deny",
      "interrogate": "deny",
      "poteto-mode": "deny",
      "principle-boundary-discipline": "deny",
      "principle-build-the-lever": "deny",
      "principle-encode-lessons-in-structure": "deny",
      "principle-exhaust-the-design-space": "deny",
      "principle-experience-first": "deny",
      "principle-fix-root-causes": "deny",
      "principle-foundational-thinking": "deny",
      "principle-guard-the-context-window": "deny",
      "principle-laziness-protocol": "deny",
      "principle-make-operations-idempotent": "deny",
      "principle-migrate-callers-then-delete-legacy-apis": "deny",
      "principle-minimize-reader-load": "deny",
      "principle-never-block-on-the-human": "deny",
      "principle-outcome-oriented-execution": "deny",
      "principle-prove-it-works": "deny",
      "principle-redesign-from-first-principles": "deny",
      "principle-separate-before-serializing-shared-state": "deny",
      "principle-sequence-verifiable-units": "deny",
      "principle-subtract-before-you-add": "deny",
      "principle-type-system-discipline": "deny",
      "recall": "deny",
      "reflect": "deny",
      "setup-pstack": "deny",
      "show-me-your-work": "deny",
      "typescript-best-practices": "deny",
      "unslop": "deny",
      "why": "deny"
    }
  },
  "agent": {
    "explore": {
      "mode": "subagent",
      "description": "Focused codebase search specialist",
      "model": "opencode-go/minimax-m3",
      "variant": "none"
    },
    "explore-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback codebase search specialist when the primary model is unavailable",
      "model": "openai/gpt-5.6-terra-fast",
      "variant": "low"
    },
    "librarian": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "variant": "high",
      "description": "External docs and examples specialist",
      "prompt": "{file:./prompts/librarian-harness.md}"
    },
    "librarian-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback docs specialist when the primary model is unavailable",
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "medium",
      "prompt": "{file:./prompts/librarian-harness.md}"
    },
    "oracle": {
      "mode": "subagent",
      "description": "Strategic consultation specialist",
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "prompt": "{file:./prompts/oracle-harness.md}"
    },
    "general": {
      "model": "openai/gpt-5.6-sol",
      "variant": "medium"
    },
    "minion": {
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "high"
    },
    "orchestrator": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh"
    }
  },
  "mcp": {
    "executor": {
      "type": "remote",
      "url": "http://127.0.0.1:4789/mcp",
      "enabled": true,
      "timeout": 30000,
      "headers": {
        "Authorization": "{env:EXECUTOR_MCP_AUTHORIZATION}"
      }
    },
    // "notion": {
    //   "type": "remote",
    //   "url": "https://mcp.notion.com/mcp"
    // },
    // "linear": {
    //   "type": "remote",
    //   "url": "https://mcp.linear.app/mcp",
    //   "enabled": true
    // },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio"
      ],
      "environment": {
        "SLACK_MCP_ENABLED_TOOLS": "channels_list,conversations_history,conversations_replies,conversations_search_messages,usergroups_list,usergroups_me",
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_XOXB_TOKEN": "{env:SLACK_MCP_XOXB_TOKEN}",
        "SLACK_MCP_XOXC_TOKEN": "{env:SLACK_MCP_XOXC_TOKEN}",
        "SLACK_MCP_XOXD_TOKEN": "{env:SLACK_MCP_XOXD_TOKEN}"
      }
    }
  }
}
