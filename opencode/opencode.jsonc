{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest"
  ],
  "small_model": "openai/gpt-5.3-codex-spark",
  "default_agent": "Scuba",
  "tools": {
    "submit_plan": false
  },
  "agent": {
    "plan": {
      "tools": {
        "submit_plan": true
      }
    },
    "PlanB": {
      "mode": "primary",
      "description": "Dialogue-first planning agent",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/planb-codex-harness.md}",
      "color": "#F3C969",
      "tools": {
        "submit_plan": true,
        "question": true
      }
    },
    "Bob": {
      "mode": "primary",
      "description": "Default build agent for ordinary repo-local work",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/bob-codex-harness.md}",
      "color": "#7DAEA3"
    },
    "Scuba": {
      "mode": "primary",
      "description": "Explicit codex-style deep-work agent",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/scuba-codex-harness.md}",
      "color": "#8A7DFF",
      "tools": {
        "submit_plan": false
      }
    },
    "explore": {
      "mode": "subagent",
      "description": "Focused codebase search specialist",
      "model": "opencode-go/minimax-m2.7",
      "prompt": "{file:./prompts/explore-codex-harness.md}"
    },
    "explore-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback codebase search specialist when Kimi is unavailable",
      "model": "openai/gpt-5.3-codex-spark",
      "prompt": "{file:./prompts/explore-codex-harness.md}"
    },
    "librarian": {
      "mode": "subagent",
      "model": "opencode-go/glm-5",
      "description": "External docs and examples specialist",
      "prompt": "{file:./prompts/librarian-codex-harness.md}"
    },
    "librarian-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback docs specialist when Kimi is unavailable",
      "model": "openai/gpt-5.3-codex-spark",
      "prompt": "{file:./prompts/librarian-codex-harness.md}"
    },
    "oracle": {
      "mode": "subagent",
      "description": "Strategic consultation specialist",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/oracle-codex-harness.md}"
    },
    "reviewer": {
      "mode": "subagent",
      "description": "Higher-rigor review specialist",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/reviewer-codex-harness.md}"
    }
  },
  "mcp": {
    "terraform": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ]
    },
    "aws-terraform": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.terraform-mcp-server@latest"
      ]
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "greptile": {
      "type": "remote",
      "url": "https://api.greptile.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:GREPTILE_API_KEY}"
      }
    }
  }
}
