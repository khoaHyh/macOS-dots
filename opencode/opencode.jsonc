{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest",
    // [
    //   "oc-plugin-vault-tec",
    //   {
    //     "enabled": false,
    //     "mode": "append"
    //   }
    // ]
  ],
  "small_model": "openai/gpt-5.4-mini",
  "lsp": true,
  "references": {
    "effect-src": {
      "path": "~/.local/share/effect-solutions/effect",
      "description": "Use when writing or reviewing Effect code, especially runtime orchestration, typed errors, services, layers, config, and tests."
    },
    "opencode-src": {
      "repository": "anomalyco/opencode",
      "description": "Use when you need good examples of architecture, design, patterns, practices and style guide in Typescript repos"
    }
  },
  "permission": {
    "websearch": "allow",
    "question": "allow"
  },
  "agent": {
    "explore": {
      "mode": "subagent",
      "description": "Focused codebase search specialist",
      "model": "opencode-go/minimax-m2.7"
    },
    "explore-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback codebase search specialist when the primary model is unavailable",
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "none"
    },
    "librarian": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "description": "External docs and examples specialist",
      "prompt": "{file:./prompts/librarian-harness.md}"
    },
    "librarian-openai-fallback": {
      "mode": "subagent",
      "description": "Fallback docs specialist when the primary model is unavailable",
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "none",
      "prompt": "{file:./prompts/librarian-harness.md}"
    },
    "oracle": {
      "mode": "subagent",
      "description": "Strategic consultation specialist",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "prompt": "{file:./prompts/oracle-harness.md}"
    }
  },
  "mcp": {
    "executor": {
      "type": "remote",
      "url": "http://127.0.0.1:4789/mcp",
      "enabled": true,
      "timeout": 30000,
      "headers": {
        "Authorization": "{env:EXECUTOR_MCP_AUTHORIZATION}"
      }
    },
    // "notion": {
    //   "type": "remote",
    //   "url": "https://mcp.notion.com/mcp"
    // },
    // "linear": {
    //   "type": "remote",
    //   "url": "https://mcp.linear.app/mcp",
    //   "enabled": true
    // },
    "greptile": {
      "type": "remote",
      "url": "https://api.greptile.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:GREPTILE_API_KEY}"
      }
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio"
      ],
      "environment": {
        "SLACK_MCP_ENABLED_TOOLS": "channels_list,conversations_history,conversations_replies,conversations_search_messages,usergroups_list,usergroups_me",
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_XOXP_TOKEN}",
        "SLACK_MCP_XOXB_TOKEN": "{env:SLACK_MCP_XOXB_TOKEN}",
        "SLACK_MCP_XOXC_TOKEN": "{env:SLACK_MCP_XOXC_TOKEN}",
        "SLACK_MCP_XOXD_TOKEN": "{env:SLACK_MCP_XOXD_TOKEN}"
      }
    }
  }
}
