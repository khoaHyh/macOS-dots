[include]
  path = ~/dev/macOS-dots/themes.gitconfig

[user]
	name = Khoa Huynh
	email = khoahuynh.toronto@gmail.com

[core]
  editor = nvim

[alias]
  staash = stash --include-untracked

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true    # use n and N to move between diff sections
  dark = true
  side-by-side = true
  true-color = always
  # features = gruvmax-fang
  # features = mellow-barbet

[merge]
  conflictStyle = zdiff3

[diff]
  colorMoved = default
